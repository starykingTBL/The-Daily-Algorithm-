---
const year = new Date().getFullYear();
---
<footer class="mt-24 border-t border-gray-200 dark:border-zinc-800">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2">
        <div class="w-5 h-5 rounded bg-blue-600 flex items-center justify-center">
          <span class="font-mono text-[8px] font-bold text-white">TDA</span>
        </div>
        <p class="text-xs text-gray-400 dark:text-zinc-500">
          © {year} The Daily Algorithm
        </p>
      </div>
      <nav class="flex items-center gap-5" aria-label="Footer">
        {[
          ['About',      '/about'      ],
          ['Privacy',    '/privacy'    ],
          ['Disclaimer', '/disclaimer' ],
        ].map(([label, href]) => (
          <a
            href={href}
            class="text-xs text-gray-400 dark:text-zinc-500
                   hover:text-gray-900 dark:hover:text-zinc-200
                   transition-colors"
          >
            {label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</footer>