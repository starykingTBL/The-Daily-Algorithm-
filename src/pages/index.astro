---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function fmt(d: Date) {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---
<BaseLayout title="Home">
  <!-- Hero -->
  <section class="border-b border-gray-200 dark:border-zinc-800">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16 sm:py-20">
      <p class="text-[11px] font-semibold tracking-[0.12em] uppercase text-blue-600 dark:text-blue-400 mb-4">
        Technology Journal
      </p>
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-gray-950 dark:text-zinc-50 leading-[1.1] mb-5 max-w-xl">
        Where algorithms<br />meet insight.
      </h1>
      <p class="text-base sm:text-lg text-gray-500 dark:text-zinc-400 max-w-md leading-relaxed">
        Deep analysis and sharp commentary on the technology shaping our world.
      </p>
    </div>
  </section>

  <!-- Articles -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    {posts.length === 0 ? (
      <div class="text-center py-20 rounded-2xl border border-dashed border-gray-300 dark:border-zinc-700">
        <div class="w-11 h-11 mx-auto mb-4 rounded-xl bg-gray-100 dark:bg-zinc-800 flex items-center justify-center text-xl">✏️</div>
        <p class="text-sm font-medium text-gray-900 dark:text-zinc-100 mb-1">No articles yet</p>
        <p class="text-sm text-gray-400 dark:text-zinc-500">Articles will appear here once published via the CMS.</p>
      </div>
    ) : (
      <div class="divide-y divide-gray-200 dark:divide-zinc-800 border border-gray-200 dark:border-zinc-800 rounded-2xl overflow-hidden">
        {posts.map((post) => (
          <article class="bg-white dark:bg-[#0a0a0a] hover:bg-gray-50/70 dark:hover:bg-zinc-900/60 transition-colors group">
            <a href={`/blog/${post.slug}`} class="block p-6">
              <div class="flex flex-wrap gap-1.5 mb-3">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class="text-[11px] font-medium px-2 py-0.5 rounded-md bg-blue-50 dark:bg-blue-950/40 text-blue-600 dark:text-blue-400">
                    {tag}
                  </span>
                ))}
              </div>
              <h2 class="text-lg sm:text-xl font-semibold text-gray-950 dark:text-zinc-50 tracking-tight leading-snug mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                {post.data.title}
              </h2>
              <p class="text-sm text-gray-500 dark:text-zinc-400 leading-relaxed mb-4 line-clamp-2">
                {post.data.description}
              </p>
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-2 text-xs text-gray-400 dark:text-zinc-500">
                  <span>{post.data.author}</span>
                  <span aria-hidden="true">·</span>
                  <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
                </div>
                <span class="text-xs font-medium text-blue-600 dark:text-blue-400 group-hover:translate-x-0.5 transition-transform">
                  Read →
                </span>
              </div>
            </a>
          </article>
        ))}
      </div>
    )}
  </section>
</BaseLayout>